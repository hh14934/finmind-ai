# FinMind AI local environment
PORT=8080

# PostgreSQL / PGVector
POSTGRES_URL=jdbc:postgresql://localhost:5432/finmind
POSTGRES_USER=finmind
POSTGRES_PASSWORD=finmind

# Ollama models
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large
OLLAMA_CHAT_TEMPERATURE=0.1

# Optional: Alpha Vantage market data. Use "demo" for limited IBM examples.
ALPHA_VANTAGE_API_KEY=demo
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co

# SEC asks automated clients to identify themselves with a User-Agent.
# Use your project/email, e.g. "FinMindAI/0.1 contact@example.com".
SEC_USER_AGENT=FinMindAI/0.1 your-email@example.com

# AI知识源工程
AI Knowledge Source_CITATION_REQUIRED=true
AI Knowledge Source_MIN_CONFIDENCE=0.80
AI Knowledge Source_SOURCE_VERIFY_DAYS=90
